# Spotify Developer Dashboard: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Refresh token (пользовательский аккаунт Spotify):
# - user-read-currently-playing — «сейчас играет» на карточке readme-spotify (опционально)
# - user-top-read — топ-3 на readme-spotify-top (обязателен для автоматического топа)
# Один refresh может содержать несколько scope, если выдали при одном входе.
SPOTIFY_REFRESH_TOKEN=

# Период для топ-3: short_term | medium_term | long_term (см. Spotify Web API)
SPOTIFY_TOP_TIME_RANGE=short_term

# Без refresh-токена API показывает этот трек (Client Credentials). По умолчанию — We Are Young.
SPOTIFY_FEATURED_TRACK_ID=5rgy6ghBq1eRApCkeUdJXf
